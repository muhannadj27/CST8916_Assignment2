# Copy this file to .env and fill in your values.
# Never commit .env to GitHub – it contains secrets.

# Connection string for your Azure Event Hubs namespace
# Found in: Azure Portal → Event Hubs namespace → Shared access policies → RootManageSharedAccessKey
EVENT_HUB_CONNECTION_STR=Endpoint=sb://YOUR_NAMESPACE.servicebus.windows.net/;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=YOUR_KEY

# Name of the hub that receives raw click events (input to Stream Analytics)
EVENT_HUB_NAME=clickstream

# Name of the hub that receives Stream Analytics output
ANALYTICS_HUB_NAME=analytics-output
